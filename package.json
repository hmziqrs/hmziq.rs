{
  "name": "hmziq.rs",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "homepage": "https://github.com/hmziqrs/hmziq.rs#readme",
  "bugs": {
    "url": "https://github.com/hmziqrs/hmziq.rs/issues"
  },
  "license": "ISC",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hmziqrs/hmziq.rs.git"
  },
  "type": "module",
  "scripts": {
    "dev": "bun build:wasm:dev && vp dev",
    "build": "bun run build:wasm && bun generate:feeds && vite build",
    "generate:feeds": "bun ./scripts/generate-feeds.ts",
    "fetch:github": "bun ./scripts/fetch-github-stats.ts",
    "copy:wasm": "bun ./scripts/copy-wasm.ts",
    "build:wasm": "cd wasm && wasm-pack build --release --target web --out-dir pkg && bun copy:wasm",
    "build:wasm:dev": "cd wasm && wasm-pack build --target web --out-dir pkg --dev && bun ../scripts/copy-wasm.ts",
    "prod": "bun run build && bun preview",
    "preview": "vite preview",
    "firebase:serve": "firebase emulators:start --only hosting",
    "firebase:deploy": "firebase deploy --only hosting",
    "firebase:build-deploy": "bun run build && firebase deploy --only hosting",
    "lint": "vp lint --type-aware --type-check",
    "lint:fix": "vp lint --type-aware --type-check --fix",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "type-check": "tsc --noEmit",
    "kill-dev": "kill -9 $(lsof -ti:3000) 2>/dev/null || true"
  },
  "dependencies": {
    "@icons-pack/react-simple-icons": "^13.5.0",
    "@react-three/fiber": "^9.1.2",
    "@tanstack/react-router": "^1.170.10",
    "@tanstack/react-start": "^1.168.18",
    "firebase": "^12.0.0",
    "framer-motion": "^12.16.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "three": "^0.177.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.1.8",
    "@tanstack/devtools-a11y": "^0.1.3",
    "@tanstack/devtools-vite": "^0.7.0",
    "@tanstack/eslint-plugin-query": "^5.100.14",
    "@tanstack/eslint-plugin-router": "^1.162.0",
    "@tanstack/react-devtools": "^0.10.5",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-devtools": "^5.100.14",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@types/three": "^0.177.0",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "feed": "^5.2.1",
    "nitro": "^3.0.260522-beta",
    "playwright": "^1.53.2",
    "sitemap": "^9.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.8.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "^0.1.24"
  },
  "overrides": {
    "vite": "$vite"
  }
}
